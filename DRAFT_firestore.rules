// Configuração de versão de regras obrigatória para suporte a caminhos aninhados avançados
rules_version = '2';
// Definição do escopo padrão de serviços do Cloud Firestore
service cloud.firestore {
  // Configuração raiz do banco de dados relacional e coleções
  match /databases/{database}/documents {

    // Regra Global de Bloqueio Primário (Default-Deny Catch-All)
    // Garante que qualquer rota não explicitamente mapeada abaixo seja sumariamente negada
    match /{document=**} {
      // Bloqueio categórico de vazamento ou escritas acidentais em caminhos órfãos
      allow read, write: if false;
    }

    // --- FUNÇÕES AUXILIARES DE COERÇÃO DE SEGURANÇA (Pilar Zero-Trust) ---

    // Valida se o ID do documento atende a padrões de tamanho razoável e caracteres seguros
    function isValidId(id) {
      // O ID deve ser string com comprimento máximo de 128 bytes para mitigar Denial of Wallet
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Atalho estruturado para capturar os recursos recebidos na payload da transação corrente
    function incoming() {
      // Retorna a representação do documento que está tentando ser salvo
      return request.resource.data;
    }

    // Atalho estruturado para referenciar os atributos do documento persistente anterior
    function existing() {
      // Retorna os dados persistidos no Firestore antes do recebimento do novo payload
      return resource.data;
    }

    // Verifica se a requisição possui credencial autenticada no Firestore Auth de forma global
    function isSignedIn() {
      // Retorna verdadeiro se o token de autorização do cabeçalho não estiver nulo
      return request.auth != null;
    }

    // --- ESQUEMAS DE VALIDAÇÃO DE ENTIDADES (Anti-Update-Gap) ---

    // Função validadora de tipagem rígida e restrição de campos extras do documento User
    function isValidUser(data) {
      // Garante que todos os campos obrigatórios estejam preenchidos com tipos e limites corretos
      return data.keys().hasAll(['id', 'nome_completo', 'matricula', 'cargo', 'email'])
             // Previne injeção de shadow fields limitando o tamanho de chaves a exatamente os atributos suportados
             && (data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAll(['stellar_wallet_address'])))
             // Validação de tipo do id profissional
             && data.id is string
             // Validação de tipo e limite de chars do nome completo do usuário para evitar poluição de memória
             && data.nome_completo is string && data.nome_completo.size() <= 200
             // Validação de tipo e conformidade da matrícula funcional do enfermeiro
             && data.matricula is string && data.matricula.size() <= 50
             // Validação de tipo e enum do cargo operacional no plantão
             && data.cargo is string && (data.cargo == 'ENF' || data.cargo == 'TE' || data.cargo == 'AE')
             // Validação de tipo e limite da string do email de segurança corporativo
             && data.email is string && data.email.size() <= 150;
    }

    // Função de validação determinística estrutural para o prontuário dos pacientes
    function isValidPatient(data) {
      // Garante presença dos atributos vitais de admissão clínica sob pena de rejeição automática
      return data.keys().hasAll(['id', 'nome_ficticio', 'numero_leito', 'setor', 'diagnostico_principal', 'status'])
             // Evita injeção de atributos não autorizados restringindo a tamanho compatível
             && data.id is string && data.id.size() <= 128
             // Nome fictício regulado por LGPD não deve ser excessivo
             && data.nome_ficticio is string && data.nome_ficticio.size() <= 150
             // Número do leito correspondente deve ser curto
             && data.numero_leito is string && data.numero_leito.size() <= 30
             // Setor de internação devidamente etiquetado
             && data.setor is string && data.setor.size() <= 100
             // Diagnóstico principal detalhado devidamente limitado para economizar carga de dados
             && data.diagnostico_principal is string && data.diagnostico_principal.size() <= 500
             // Restição estrita de status clínico para transições de estado controladas
             && data.status is string && (data.status == 'internado' || data.status == 'alta' || data.status == 'transferido' || data.status == 'obito');
    }

    // Função de verificação para medições de sinais vitais e prontuários evolutivos
    function isValidMetricPoint(data) {
      // Todos os parâmetros de sinais vitais de monitorização devem constar na payload enviada
      return data.keys().hasAll(['time', 'temp', 'spo2', 'pain', 'sys', 'dia', 'paciente_id'])
             // Valida o tempo indexado
             && data.time is string && data.time.size() <= 10
             // Valida limite de temperatura de segurança térmica humana
             && data.temp is number && data.temp >= 30.0 && data.temp <= 45.0
             // Oxigenação do sangue medida em porcentagem máxima
             && data.spo2 is number && data.spo2 >= 0 && data.spo2 <= 100
             // Escala visual analógica de dor regulamentada de zero a dez
             && data.pain is number && data.pain >= 0 && data.pain <= 10
             // Pressão arterial sistólica máxima
             && data.sys is number && data.sys >= 0 && data.sys <= 300
             // Pressão arterial diastólica máxima
             && data.dia is number && data.dia >= 0 && data.dia <= 200
             // Garante que o ponto métrico esteja vinculado a um prontuário de paciente
             && data.paciente_id is string && data.paciente_id.size() <= 128;
    }

    // --- DECLARAÇÕES DE REGRAS POR CAMINHO ESPECÍFICO ---

    // Coleção de Perfis de Usuários (Enfermeiros)
    match /users/{userId} {
      // Regra de leitura: Apenas o próprio usuário autenticado pode ler seus dados cadastrais (Zero-PII Leak)
      allow read, get: if isSignedIn() && request.auth.uid == userId;
      
      // Regra de inserção: Apenas o próprio usuário pode criar seu registro vinculando-se à chave Auth correspondente
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      // Regra de atualização: Proíbe escalação de privilégios e alterações de cargo ou matrícula de forma arbitrária
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                       // Restringe a alteração apenas aos dados cadastrais editáveis como nome ou email de contato
                       && incoming().diff(existing()).affectedKeys().hasOnly(['nome_completo', 'email', 'stellar_wallet_address']);
                       
      // Regra de deleção: Exclusão de contas profissionais é terminantemente proibida por motivos de auditoria jurídica
      allow delete: if false;
    }

    // Coleção Principal de Internações e Ficha de Pacientes
    match /patients/{patientId} {
      // Qualquer enfermeiro cadastrado no posto do plantão clínico está autorizado a listar ou obter prontuários
      allow read, get, list: if isSignedIn();
      
      // Permite aos enfermeiros admitir novos pacientes com dados válidos e ID seguro
      allow create: if isSignedIn() && isValidId(patientId) && isValidPatient(incoming());
      
      // Permite atualizações cadastrais ou evolução de status, garantindo integridade de estado final
      allow update: if isSignedIn() && isValidId(patientId) && isValidPatient(incoming())
                       // Trava de Estado Terminal: Pacientes que receberam alta, óbito ou transferência são congelados contra adulteração retroativa
                       && (existing().status == 'internado' || (existing().status != 'internado' && incoming().status == existing().status));

      // Deleção física de prontuários é rigidamente bloqueada para manter registros clínicos intocáveis
      allow delete: if false;
      
      // Subcoleção de Evoluções e Sinais Vitais dos Pacientes
      match /metrics/{metricId} {
        // Leitura de sinais vitais permitida para todos os membros do plantão atuantes
        allow read, get, list: if isSignedIn();
        
        // Registro de novos exames, sinais ou evoluções de diurese e dor na ficha clínica
        allow create: if isSignedIn() && isValidId(metricId) && isValidId(patientId)
                         // Garante que a métrica recebida esteja no formato estruturado e atrelada ao id correto
                         && isValidMetricPoint(incoming()) && incoming().paciente_id == patientId
                         // Validação de consistência relacional: Impede o registro de sinais se o prontuário do paciente pai não existir no Firestore
                         && exists(/databases/$(database)/documents/patients/$(patientId));
                         
        // Bloqueia atualizações retroativas em medições históricas de aferição uma vez consolidadas
        allow update: if isSignedIn() && isValidId(metricId) && isValidId(patientId)
                         && isValidMetricPoint(incoming()) && incoming().paciente_id == patientId
                         // Impede modificação de chaves históricas ou reatribuição de prontuário
                         && incoming().diff(existing()).affectedKeys().hasOnly(['temp', 'spo2', 'pain', 'sys', 'dia', 'fc', 'fr', 'diurese_anomalia', 'evolutionData']);
                         
        // Bloqueia exclusões de exames para assegurar que o histórico médico nunca seja apagado pelo operador
        allow delete: if false;
      }
    }
  }
}
